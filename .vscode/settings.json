{
  // Associate .qvs files with Qlik script language
  "files.associations": {
    "*.qvs": "qlik"
  },
  
  // Optional: Configure editor settings for Qlik scripts
  "[qlik]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.formatOnSave": false,
    "editor.wordWrap": "on"
  },
  
  // File encoding
  "files.encoding": "utf8",
  
  // Exclude patterns (optional)
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true
  }
}

