// ============================================// LOAD - Load transformed data to final model// ============================================// Load transformed dataTransformedData:Load    *From    [lib://Datafiles/02_Transform_TransformedData.qvd](qvd);// Create final fact tableFactOrders:Load    RecordID,    CustomerName,    OrderDate,    OrderAmount,    OrderCategory,    OrderYear,    OrderMonth,    OrderWeek,    ExtractTimestampResident    TransformedData;// Create dimension table for customersDimCustomers:Load    CustomerName,    Sum(OrderAmount)           as TotalOrderAmount,    Count(RecordID)            as OrderCount,    Max(OrderDate)             as LastOrderDateResident    TransformedDataGroup By    CustomerName;// Create dimension table for datesDimDates:Load    OrderDate,    OrderYear,    OrderMonth,    OrderWeek,    Year(OrderDate)            as Year,    Month(OrderDate)           as Month,    Week(OrderDate)            as Week,    Day(OrderDate)             as Day,    WeekDay(OrderDate)         as WeekDayResident    TransformedDataGroup By    OrderDate,    OrderYear,    OrderMonth,    OrderWeek;// Drop temporary tableDrop Table TransformedData;// Store final tables to QVDStore FactOrders into [lib://Datafiles/03_Load_FactOrders.qvd](qvd);Store DimCustomers into [lib://Datafiles/03_Load_DimCustomers.qvd](qvd);Store DimDates into [lib://Datafiles/03_Load_DimDates.qvd](qvd);;